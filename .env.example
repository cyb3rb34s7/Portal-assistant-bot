# CurationPilot — local environment template.
#
# Copy this file to ".env" and fill in the values you actually use.
# ".env" is gitignored; ".env.example" is committed as documentation.
#
# All values are read by python-dotenv when the pilot package imports
# (see pilot/__init__.py). Variables already set in the shell take
# precedence over the .env file.

# ---- LLM provider credentials (set the one(s) you use) ------------

# Groq — fast, cheap; default for intake / clarify / reporter stages.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — works against api.openai.com or any OAI-compatible endpoint.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint.example/v1

# AWS Bedrock — multi-family (Claude, Llama, Nova, Mistral) via Converse.
# Auth comes from the standard AWS chain (~/.aws/credentials, env, IAM).
# AWS_REGION=us-east-1

# Internal org LLM (skeleton — endpoint not registered until you wire
# it in pilot/agent/ai_client/adapters/custom_org.py).
# CURATIONPILOT_CUSTOM_ORG_ENDPOINT=https://internal-llm.example/v1
# CURATIONPILOT_CUSTOM_ORG_TOKEN=

# ---- Per-stage model overrides (optional) -------------------------
# If unset, each stage uses the AIClient's default_model.

# CURATIONPILOT_GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
# CURATIONPILOT_OPENAI_DEFAULT_MODEL=gpt-4o-mini
# CURATIONPILOT_BEDROCK_DEFAULT_MODEL=anthropic.claude-sonnet-4-20250929-v1:0
# CURATIONPILOT_CUSTOM_ORG_DEFAULT_MODEL=

# Default client when --client isn't passed. Options: groq, openai,
# bedrock, custom_org, mock.
# CURATIONPILOT_AI_CLIENT=groq
